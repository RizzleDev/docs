{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Birdb",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "icon": "book-open-cover",
          "href": "https://birbdbot.dev"
        }
      ]
    },
    "dropdowns": [
      {
        "dropdown": "Home",
        "anchors": [
          {
            "anchor": "Home",
            "tabs": [
              {
                "tab": "Get Started",
                "pages": [
                  "getting-started",
                  "commands"
                ]
              },
              {
                "tab": "Features",
                "pages": [
                  "auto-moderation",
                  "server-statistics"
                ]
              },
              {
                "tab": "Help Center",
                "pages": [
                  "buying-and-enabling-plus-guide"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": "/images/logo-removebg-preview.png",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://discord.gg/FF7mJ9z6jn"
      },
      {
        "label": "Premium",
        "href": "https://birbdbot.dev/premium"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "thumbnails": {
    "background": "/images/banner.png"
  }
}
